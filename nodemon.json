{
  "watch": [
    "server.js",
    "scripts/**/*.js",
    "scripts/**/*.cjs",
    "routes/**/*.js",
    ".env"
  ],
  "ignore": [
    "node_modules/**/*",
    "angular/**/*",
    "dist/**/*",
    "coverage/**/*",
    "*.backup",
    "*.log",
    ".git/**/*"
  ],
  "ext": "js,json,cjs",
  "delay": 1000,
  "verbose": false,
  "restartable": "rs",
  "env": {
    "NODE_ENV": "development"
  },
  "execMap": {
    "js": "node"
  }
}
