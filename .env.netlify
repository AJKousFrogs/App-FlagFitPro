SUPABASE_URL=your_supabase_project_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
# SUPABASE_SERVICE_ROLE_KEY is the Netlify-standard name and is accepted as a fallback.
# The primary name checked by code is SUPABASE_SERVICE_KEY — set either one.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
NODE_ENV=production
