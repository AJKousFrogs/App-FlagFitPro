{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "flagfit-pro": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss",
          "standalone": true
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "preserveSymlinks": true,
            "outputPath": "dist/flagfit-pro",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": [],
            "tsConfig": "tsconfig.app.json",
            "assets": [
              "src/favicon.ico",
              "src/assets",
              "src/manifest.webmanifest",
              "src/manifest.json",
              {
                "glob": "robots.txt",
                "input": "src/assets",
                "output": "/"
              }
            ],
            "serviceWorker": "ngsw-config.json",
            "styles": ["src/styles.scss"],
            "scripts": [],
            "stylePreprocessorOptions": {
              "includePaths": ["src", "node_modules"]
            },
            "allowedCommonJsDependencies": [
              "canvg",
              "core-js",
              "raf",
              "rgbcolor",
              "html2canvas",
              "jspdf"
            ],
            "outputMode": "static"
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "1.51mb",
                  "maximumError": "1.51mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "45kb",
                  "maximumError": "50kb"
                },
                {
                  "type": "anyScript",
                  "maximumWarning": "450kb",
                  "maximumError": "600kb"
                },
                {
                  "type": "any",
                  "maximumWarning": "450kb",
                  "maximumError": "600kb"
                }
              ],
              "namedChunks": true,
              "outputHashing": "all",
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.prod.ts"
                }
              ],
              "optimization": {
                "scripts": true,
                "styles": {
                  "minify": true,
                  "inlineCritical": true,
                  "removeSpecialComments": true
                },
                "fonts": {
                  "inline": true
                }
              },
              "sourceMap": false,
              "extractLicenses": true
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "port": 4200,
            "host": "0.0.0.0",
            "open": false,
            "liveReload": true,
            "poll": 2000
          },
          "configurations": {
            "production": {
              "buildTarget": "flagfit-pro:build:production"
            },
            "development": {
              "buildTarget": "flagfit-pro:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "tsconfig.spec.json",
            "buildTarget": "flagfit-pro:build"
          }
        },
        "storybook": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "browserTarget": "flagfit-pro:build",
            "port": 6006,
            "compodoc": false,
            "tsConfig": ".storybook/tsconfig.json"
          }
        },
        "build-storybook": {
          "builder": "@storybook/angular:build-storybook",
          "options": {
            "browserTarget": "flagfit-pro:build",
            "compodoc": false,
            "outputDir": "storybook-static"
          }
        },
        "serve-ssr": {
          "builder": "@angular-devkit/build-angular:ssr-dev-server",
          "configurations": {
            "production": {
              "buildTarget": "flagfit-pro:build:production",
              "serverTarget": "flagfit-pro:server:production"
            },
            "development": {
              "buildTarget": "flagfit-pro:build:development",
              "serverTarget": "flagfit-pro:server:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "prerender": {
          "builder": "@angular-devkit/build-angular:prerender",
          "options": {
            "routes": ["/", "/login", "/register", "/reset-password"]
          }
        },
        "server": {
          "builder": "@angular-devkit/build-angular:application-server",
          "options": {
            "outputPath": "dist/flagfit-pro/server",
            "main": "server.ts",
            "tsConfig": "tsconfig.server.json",
            "optimization": true,
            "sourceMap": false
          },
          "configurations": {
            "production": {
              "outputHashing": "all",
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.prod.ts"
                }
              ],
              "sourceMap": false,
              "optimization": true
            },
            "development": {
              "optimization": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        }
      }
    }
  },
  "schematics": {
    "@schematics/angular:component": {
      "type": "component"
    },
    "@schematics/angular:directive": {
      "type": "directive"
    },
    "@schematics/angular:service": {
      "type": "service"
    },
    "@schematics/angular:guard": {
      "typeSeparator": "."
    },
    "@schematics/angular:interceptor": {
      "typeSeparator": "."
    },
    "@schematics/angular:module": {
      "typeSeparator": "."
    },
    "@schematics/angular:pipe": {
      "typeSeparator": "."
    },
    "@schematics/angular:resolver": {
      "typeSeparator": "."
    }
  }
}
