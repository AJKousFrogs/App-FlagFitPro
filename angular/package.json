{
  "name": "flagfit-pro-angular",
  "type": "module",
  "version": "4.0.0",
  "description": "FlagFit Pro v4.0 - primary Angular application for athlete, coach, and team workflows",
  "packageManager": "npm@11.4.2",
  "engines": {
    "node": ">=22.22.3"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:ssr": "ng serve-ssr",
    "prebuild": "npm run check:ngmodel-cva",
    "build": "ng build --progress=false",
    "build:analyze": "ng build && node scripts/check-bundle-size.js",
    "serve:dist": "node scripts/serve-dist.mjs",
    "watch": "ng build --watch --configuration development",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:smoke": "playwright test e2e/smoke.spec.ts",
    "e2e:onboarding": "playwright test e2e/onboarding-route.spec.ts",
    "e2e:critical": "playwright test e2e/critical-flow-morning-training.spec.ts",
    "e2e:navigation": "playwright test e2e/navigation-routing.spec.ts",
    "e2e:navigation:watch": "playwright test e2e/navigation-routing.spec.ts --headed",
    "e2e:design-system": "FORCE_COLOR=0 playwright test --project=design-system",
    "e2e:design-system:watch": "playwright test --project=design-system --headed",
    "e2e:design-system:ui": "playwright test --project=design-system --ui",
    "e2e:visual": "playwright test --project=visual-regression",
    "e2e:visual:update": "playwright test --project=visual-regression --update-snapshots",
    "e2e:visual:ui": "playwright test --project=visual-regression --ui",
    "e2e:visual:mobile": "playwright test --project=visual-regression-mobile",
    "e2e:visual:mobile:update": "playwright test --project=visual-regression-mobile --update-snapshots",
    "e2e:visual:tablet": "playwright test --project=visual-regression-tablet",
    "e2e:visual:tablet:update": "playwright test --project=visual-regression-tablet --update-snapshots",
    "e2e:visual:all": "playwright test --project=visual-regression --project=visual-regression-mobile --project=visual-regression-tablet",
    "e2e:visual:all:update": "playwright test --project=visual-regression --project=visual-regression-mobile --project=visual-regression-tablet --update-snapshots",
    "bundle:check": "node scripts/check-bundle-size.js",
    "lint": "eslint \"src/app/**/*.{ts,html}\"",
    "lint:fix": "eslint \"src/app/**/*.{ts,html}\" --fix",
    "lint:app": "npm run lint",
    "lint:css": "node ../node_modules/stylelint/bin/stylelint.mjs --config ../stylelint.config.js --ignore-path ../.stylelintignore \"src/**/*.{css,scss}\"",
    "lint:css:fix": "node ../node_modules/stylelint/bin/stylelint.mjs --config ../stylelint.config.js --ignore-path ../.stylelintignore \"src/**/*.{css,scss}\" --fix",
    "storybook": "ng run flagfit-pro:storybook",
    "build-storybook": "ng run flagfit-pro:build-storybook",
    "type-check": "tsc --noEmit",
    "audit:a11y": "npx tsx src/scripts/accessibility-audit.ts",
    "audit:a11y:ci": "BASE_URL=${BASE_URL:-http://127.0.0.1:4200} npm run audit:a11y",
    "check:ngmodel-cva": "node scripts/check-no-bidirectional-ngmodel.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~21.2.2",
    "@angular/cdk": "~21.2.2",
    "@angular/common": "~21.2.2",
    "@angular/compiler": "~21.2.2",
    "@angular/core": "~21.2.2",
    "@angular/forms": "~21.2.2",
    "@angular/platform-browser": "~21.2.2",
    "@angular/platform-server": "~21.2.2",
    "@angular/router": "~21.2.2",
    "@angular/service-worker": "~21.2.2",
    "@angular/ssr": "~21.2.2",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@standard-schema/spec": "^1.0.0",
    "@supabase/supabase-js": "^2.108.2",
    "chart.js": "^4.5.1",
    "date-fns": "^4.4.0",
    "express": "^5.1.0",
    "html2canvas": "^1.4.1",
    "iconify-icon": "^3.0.2",
    "jspdf": "^4.2.1",
    "lucide-angular": "^1.0.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.3.1",
    "@analogjs/vitest-angular": "^2.3.1",
    "@angular-devkit/build-angular": "~21.2.2",
    "@angular/build": "~22.0.4",
    "@angular/cli": "~21.2.2",
    "@angular/compiler-cli": "~21.2.2",
    "@angular/platform-browser-dynamic": "~21.2.2",
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^10.0.1",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify/utils": "^3.1.3",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-links": "^10.4.6",
    "@storybook/angular": "^10.4.6",
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "angular-eslint": "21.3.0",
    "eslint": "^10.5.0",
    "eslint-plugin-storybook": "^10.4.6",
    "globals": "^17.3.0",
    "jsdom": "^29.1.1",
    "storybook": "^10.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "8.62.0",
    "vitest": "^4.1.9"
  },
  "browserslist": [
    "chrome 120",
    "edge 120",
    "firefox 120",
    "safari 17",
    "ios_saf 17"
  ]
}
