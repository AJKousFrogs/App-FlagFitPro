{
  "name": "flagfit-pro-angular",
  "version": "1.1.0",
  "description": "FlagFit Pro - Primary application built with Angular 21 + PrimeNG 21",
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:ssr": "ng serve-ssr",
    "build": "npx ng build --progress=false --verbose",
    "build:analyze": "ng build && node scripts/check-bundle-size.js",
    "build:ssr": "ng build && ng run flagfit-pro:server",
    "build:prerender": "ng build && ng run flagfit-pro:prerender",
    "watch": "ng build --watch --configuration development",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:smoke": "playwright test e2e/smoke.spec.ts",
    "e2e:critical": "playwright test e2e/critical-flow-morning-training.spec.ts",
    "e2e:navigation": "playwright test e2e/navigation-routing.spec.ts",
    "e2e:navigation:watch": "playwright test e2e/navigation-routing.spec.ts --headed",
    "e2e:design-system": "playwright test --project=design-system",
    "e2e:design-system:watch": "playwright test --project=design-system --headed",
    "e2e:design-system:ui": "playwright test --project=design-system --ui",
    "e2e:visual": "playwright test --project=visual-regression",
    "e2e:visual:update": "playwright test --project=visual-regression --update-snapshots",
    "e2e:visual:ui": "playwright test --project=visual-regression --ui",
    "e2e:visual:mobile": "playwright test --project=visual-regression-mobile",
    "e2e:visual:mobile:update": "playwright test --project=visual-regression-mobile --update-snapshots",
    "e2e:visual:tablet": "playwright test --project=visual-regression-tablet",
    "e2e:visual:tablet:update": "playwright test --project=visual-regression-tablet --update-snapshots",
    "e2e:visual:all": "playwright test --project=visual-regression --project=visual-regression-mobile --project=visual-regression-tablet",
    "e2e:visual:all:update": "playwright test --project=visual-regression --project=visual-regression-mobile --project=visual-regression-tablet --update-snapshots",
    "bundle:check": "node scripts/check-bundle-size.js",
    "lint": "eslint \"src/app/**/*.{ts,html}\"",
    "lint:fix": "eslint \"src/app/**/*.{ts,html}\" --fix",
    "lint:app": "npm run lint",
    "postinstall": "node scripts/patch-html2canvas.js && node scripts/patch-primeng-regexp.js",
    "storybook": "ng run flagfit-pro:storybook",
    "build-storybook": "ng run flagfit-pro:build-storybook",
    "serve:ssr:flagfit-pro": "node dist/flagfit-pro/server/server.mjs",
    "type-check": "tsc --noEmit"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.1.3",
    "@angular/aria": "^21.1.3",
    "@angular/cdk": "^21.1.3",
    "@angular/common": "^21.1.3",
    "@angular/compiler": "^21.1.3",
    "@angular/core": "^21.1.3",
    "@angular/forms": "^21.1.3",
    "@angular/platform-browser": "^21.1.3",
    "@angular/platform-server": "^21.1.3",
    "@angular/router": "^21.1.3",
    "@angular/service-worker": "^21.1.3",
    "@angular/ssr": "^21.1.3",
    "@primeuix/themes": "^2.0.3",
    "@standard-schema/spec": "^1.0.0",
    "@supabase/supabase-js": "^2.95.3",
    "chart.js": "^4.5.1",
    "date-fns": "^4.1.0",
    "express": "^5.1.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.1.0",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.1",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.16.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.2.3",
    "@analogjs/vitest-angular": "^2.2.3",
    "@angular-devkit/build-angular": "^21.1.3",
    "@angular/build": "^21.1.3",
    "@angular/cli": "^21.1.3",
    "@angular/compiler-cli": "^21.1.3",
    "@angular/platform-browser-dynamic": "^21.1.3",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.2.8",
    "@storybook/addon-docs": "^10.2.8",
    "@storybook/addon-links": "^10.2.8",
    "@storybook/angular": "^10.2.8",
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.0",
    "@vitest/ui": "^4.0.18",
    "angular-eslint": "^21.2.0",
    "eslint": "^9.39.2",
    "eslint-plugin-storybook": "^10.2.8",
    "globals": "^17.3.0",
    "ignore-loader": "^0.1.2",
    "jsdom": "^27.4.0",
    "storybook": "^10.2.8",
    "tinyexec": "^1.0.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "vitest": "^4.0.18"
  },
  "browserslist": [
    "chrome 120",
    "edge 120",
    "firefox 120",
    "safari 17",
    "ios_saf 17"
  ]
}