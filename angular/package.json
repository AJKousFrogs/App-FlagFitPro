{
  "name": "flagfit-pro-angular",
  "version": "1.0.0",
  "description": "FlagFit Pro - Primary application built with Angular 21 + PrimeNG 21",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:ssr": "ng serve-ssr",
    "build": "ng build",
    "build:ssr": "ng build && ng run flagfit-pro:server",
    "build:prerender": "ng build && ng run flagfit-pro:prerender",
    "watch": "ng build --watch --configuration development",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.0.3",
    "@angular/aria": "21.0.3",
    "@angular/cdk": "^21.0.3",
    "@angular/common": "^21.0.3",
    "@angular/compiler": "^21.0.6",
    "@angular/core": "^21.0.3",
    "@angular/fire": "^21.0.0-rc.0",
    "@angular/forms": "^21.0.3",
    "@angular/material": "^21.0.3",
    "@angular/platform-browser": "^21.0.3",
    "@angular/platform-server": "^21.0.3",
    "@angular/router": "^21.0.3",
    "@angular/ssr": "^21.0.3",
    "@angular/youtube-player": "^21.0.0",
    "@standard-schema/spec": "^1.0.0",
    "@supabase/supabase-js": "^2.88.0",
    "chart.js": "^4.5.1",
    "express": "^4.22.1",
    "firebase": "^11.10.0",
    "primeicons": "^7.0.0",
    "primeng": "^21.0.2",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.0.3",
    "@angular/cli": "^21.0.3",
    "@angular/compiler-cli": "^21.0.6",
    "@angular/platform-browser-dynamic": "^21.0.6",
    "@types/node": "^24.10.1",
    "@vitest/ui": "^4.0.15",
    "jsdom": "^27.3.0",
    "typescript": "~5.9.3",
    "vitest": "^4.0.15"
  },
  "peerDependencies": {
    "zone.js": "~0.16.0"
  },
  "peerDependenciesMeta": {
    "zone.js": {
      "optional": true
    }
  }
}
