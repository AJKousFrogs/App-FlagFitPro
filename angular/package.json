{
  "name": "flagfit-pro-angular",
  "version": "1.1.0",
  "description": "FlagFit Pro - Primary application built with Angular 21 + PrimeNG 21",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:ssr": "ng serve-ssr",
    "build": "ng build",
    "build:analyze": "ng build && node scripts/check-bundle-size.js",
    "build:ssr": "ng build && ng run flagfit-pro:server",
    "build:prerender": "ng build && ng run flagfit-pro:prerender",
    "watch": "ng build --watch --configuration development",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "bundle:check": "node scripts/check-bundle-size.js"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/aria": "^21.0.0",
    "@angular/cdk": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/material": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-server": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@angular/service-worker": "^21.0.0",
    "@angular/ssr": "^21.0.0",
    "@angular/youtube-player": "^21.0.0",
    "@standard-schema/spec": "^1.0.0",
    "@supabase/supabase-js": "^2.89.0",
    "chart.js": "^4.5.1",
    "express": "^5.2.1",
    "primeicons": "^7.0.0",
    "primeng": "^21.0.2",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.16.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.0",
    "@types/node": "^22.15.0",
    "@vitest/ui": "^4.0.16",
    "jsdom": "^27.4.0",
    "source-map-explorer": "^2.5.3",
    "typescript": "~5.9.3",
    "vitest": "^4.0.16"
  }
}
