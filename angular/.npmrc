# The @angular/* packages currently sit at mixed 21.2.x patch levels (a residue of
# staggered Dependabot bumps), which trips npm's strict peer resolver. CI installs
# with --legacy-peer-deps; pin the same behaviour here so `npm ci` is identical
# everywhere — local, CI, and Netlify (whose build command runs a plain `npm ci`).
legacy-peer-deps=true
