{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "allowJs": true,
    "checkJs": false,
    "jsx": "preserve",
    "strict": false,
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*", "routes/**/*", "scripts/**/*", "*.js", "*.html"],
  "exclude": [
    "node_modules/**",
    "dist",
    ".netlify",
    "database",
    "docs",
    "**/*.test.js",
    "**/*.spec.js"
  ]
}
