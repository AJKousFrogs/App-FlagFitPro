{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "allowJs": true,
    "checkJs": false,
    "jsx": "preserve",
    "strict": false,
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": "."
  },
  "include": ["src/**/*", "routes/**/*", "scripts/**/*.js"],
  "exclude": [
    "node_modules",
    "node_modules.old",
    "dist",
    ".netlify",
    "database",
    "docs",
    "angular",
    "backups",
    "tests",
    "**/*.test.js",
    "**/*.spec.js",
    "**/*.d.ts",
    "**/node_modules/**"
  ],
  "typeAcquisition": {
    "enable": false
  }
}
