# Flag Football Training App - Environment Variables

# Development Server Configuration
VITE_DEV_PORT=4000
VITE_HMR_PORT=4000
VITE_PREVIEW_PORT=4173

# File Watching Configuration (for development issues)
# Set to 'true' if you experience file watching issues in Docker, WSL, etc.
VITE_USE_POLLING=false
# Polling interval in milliseconds (1000 = 1 second)
VITE_WATCH_INTERVAL=100

# Database Configuration
VITE_NEON_DATABASE_URL=your_neon_database_url_here

# PocketBase Configuration (if using legacy auth)
VITE_POCKETBASE_URL=http://127.0.0.1:8090

# Application Configuration
VITE_APP_NAME="FlagFit Pro"
VITE_APP_VERSION="1.0.7"
VITE_APP_ENVIRONMENT=development

# MCP Configuration
VITE_ENABLE_MCP=true
CONTEXT7_API_KEY=your_context7_api_key_here
MCP_CONTEXT7_PORT=3000
MCP_SEQUENTIAL_THOUGHT_PORT=3001

# Development Tools
VITE_ENABLE_DEVTOOLS=true

# Common Environment Troubleshooting:
# 
# If hot reload isn't working:
# 1. Set VITE_USE_POLLING=true
# 2. Increase VITE_WATCH_INTERVAL to 1000 or 2000
# 
# For Docker containers:
# - Set VITE_USE_POLLING=true automatically detected
# 
# For WSL (Windows Subsystem for Linux):
# - Set VITE_USE_POLLING=true automatically detected
# 
# For network drives or slow file systems:
# - Set VITE_WATCH_INTERVAL=2000 or higher

# =============================================================================
# SUPABASE CONFIGURATION (PRIMARY AUTH SYSTEM)
# =============================================================================
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# =============================================================================
# THIRD-PARTY INTEGRATIONS
# =============================================================================

# YouTube API (for training videos and drill demonstrations)
VITE_YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_API_QUOTA_LIMIT=10000

# Weather API (for outdoor training conditions)
WEATHER_API_KEY=your_openweather_api_key_here
WEATHER_API_URL=https://api.openweathermap.org/data/2.5

# Nutrition Database API (USDA FoodData Central)
USDA_API_KEY=your_usda_api_key_here
USDA_API_URL=https://api.nal.usda.gov/fdc/v1

# GPS/Wearable Device Integration
GARMIN_API_KEY=your_garmin_api_key_here
FITBIT_CLIENT_ID=your_fitbit_client_id_here
APPLE_HEALTH_KIT_ENABLED=false

# =============================================================================
# ANALYTICS & MONITORING
# =============================================================================

# Google Analytics (for user behavior tracking)
VITE_GOOGLE_ANALYTICS_ID=your_ga_measurement_id_here
VITE_GOOGLE_TAG_MANAGER_ID=your_gtm_id_here

# Sentry (for error tracking and performance monitoring)
VITE_SENTRY_DSN=your_sentry_dsn_here
SENTRY_AUTH_TOKEN=your_sentry_auth_token_here
SENTRY_ORG=your_sentry_org_here
SENTRY_PROJECT=flagfit-pro

# PostHog (for product analytics)
VITE_POSTHOG_KEY=your_posthog_key_here
VITE_POSTHOG_HOST=https://app.posthog.com

# =============================================================================
# COMMUNICATION SERVICES
# =============================================================================

# SendGrid (for email notifications)
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@flagfitpro.com

# Gmail SMTP (alternative email service)
GMAIL_EMAIL=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16_character_app_password

# Generic SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@domain.com
SMTP_PASS=your_email_password

# Email Settings
FROM_EMAIL=noreply@flagfitpro.com
APP_URL=http://localhost:4000

# Twilio (for SMS notifications)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here

# Push Notifications (Firebase)
FIREBASE_PROJECT_ID=your_firebase_project_id_here
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_MESSAGING_SENDER_ID=your_firebase_sender_id_here

# =============================================================================
# AI & MACHINE LEARNING SERVICES
# =============================================================================

# OpenAI (for AI coach and advanced analytics)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_ORG_ID=your_openai_org_id_here

# Anthropic Claude (alternative AI service)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Custom AI Service URLs
VITE_AI_SERVICE_URL=http://localhost:8080
AI_MODEL_VERSION=gpt-4-turbo-preview

# =============================================================================
# PAYMENT & SUBSCRIPTION SERVICES
# =============================================================================

# Stripe (for subscription payments)
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# =============================================================================
# CONTENT DELIVERY & STORAGE
# =============================================================================

# AWS S3 (for file storage)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1
AWS_S3_BUCKET=flagfit-pro-uploads

# Cloudinary (for image/video processing)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# =============================================================================
# SECURITY & AUTHENTICATION
# =============================================================================

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here

# CSRF Protection
CSRF_SECRET=your_csrf_secret_key_here

# =============================================================================
# COMPLIANCE & LEGAL
# =============================================================================

# GDPR Compliance
PRIVACY_POLICY_URL=https://flagfitpro.com/privacy
TERMS_OF_SERVICE_URL=https://flagfitpro.com/terms
COOKIE_CONSENT_ENABLED=true

# Data Retention Policies
USER_DATA_RETENTION_DAYS=2555  # 7 years
ANALYTICS_DATA_RETENTION_DAYS=365
LOG_RETENTION_DAYS=90
