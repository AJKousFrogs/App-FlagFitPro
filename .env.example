# Flag Football Training App - Environment Variables

# Development Server Configuration
VITE_DEV_PORT=4000
VITE_HMR_PORT=4000
VITE_PREVIEW_PORT=4173

# File Watching Configuration (for development issues)
# Set to 'true' if you experience file watching issues in Docker, WSL, etc.
VITE_USE_POLLING=false
# Polling interval in milliseconds (1000 = 1 second)
VITE_WATCH_INTERVAL=100

# Database Configuration
VITE_NEON_DATABASE_URL=your_neon_database_url_here

# PocketBase Configuration (if using legacy auth)
VITE_POCKETBASE_URL=http://127.0.0.1:8090

# Application Configuration
VITE_APP_NAME="FlagFit Pro"
VITE_APP_VERSION="1.0.7"
VITE_APP_ENVIRONMENT=development

# MCP Configuration
VITE_ENABLE_MCP=true
CONTEXT7_API_KEY=your_context7_api_key_here
MCP_CONTEXT7_PORT=3000
MCP_SEQUENTIAL_THOUGHT_PORT=3001

# Development Tools
VITE_ENABLE_DEVTOOLS=true

# Common Environment Troubleshooting:
# 
# If hot reload isn't working:
# 1. Set VITE_USE_POLLING=true
# 2. Increase VITE_WATCH_INTERVAL to 1000 or 2000
# 
# For Docker containers:
# - Set VITE_USE_POLLING=true automatically detected
# 
# For WSL (Windows Subsystem for Linux):
# - Set VITE_USE_POLLING=true automatically detected
# 
# For network drives or slow file systems:
# - Set VITE_WATCH_INTERVAL=2000 or higher