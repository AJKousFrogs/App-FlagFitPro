# Flag Football Training App - Environment Variables

# Development Server Configuration
VITE_DEV_PORT=4000
VITE_HMR_PORT=4000
VITE_PREVIEW_PORT=4173

# File Watching Configuration (for development issues)
# Set to 'true' if you experience file watching issues in Docker, WSL, etc.
VITE_USE_POLLING=false
# Polling interval in milliseconds (1000 = 1 second)
VITE_WATCH_INTERVAL=100

# Application Configuration
VITE_APP_NAME="FlagFit Pro"
VITE_APP_VERSION="11.0.0"
VITE_APP_ENVIRONMENT=development

# MCP Configuration (local dev tooling only)
VITE_ENABLE_MCP=true
CONTEXT7_API_KEY=your_context7_api_key_here
MCP_CONTEXT7_PORT=3000
MCP_SEQUENTIAL_THOUGHT_PORT=3001

# Development Tools
VITE_ENABLE_DEVTOOLS=true

# Common Environment Troubleshooting:
#
# If hot reload isn't working:
# 1. Set VITE_USE_POLLING=true
# 2. Increase VITE_WATCH_INTERVAL to 1000 or 2000
#
# For Docker containers:
# - Set VITE_USE_POLLING=true automatically detected
#
# For WSL (Windows Subsystem for Linux):
# - Set VITE_USE_POLLING=true automatically detected
#
# For network drives or slow file systems:
# - Set VITE_WATCH_INTERVAL=2000 or higher

# =============================================================================
# SUPABASE CONFIGURATION (PRIMARY AUTH + DATABASE)
# =============================================================================
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Code in supabase-client.js checks SUPABASE_SERVICE_KEY first, then SUPABASE_SERVICE_ROLE_KEY.
# Set either one — both are accepted. SUPABASE_SERVICE_KEY is preferred for new setups.
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# =============================================================================
# THIRD-PARTY INTEGRATIONS
# =============================================================================

# Nutrition Database API (USDA FoodData Central — used by supabase/functions/search-usda-foods)
USDA_API_KEY=your_usda_api_key_here
USDA_API_URL=https://api.nal.usda.gov/fdc/v1

# =============================================================================
# ANALYTICS & MONITORING
# =============================================================================

# Sentry (for error tracking and performance monitoring)
VITE_SENTRY_DSN=your_sentry_dsn_here
SENTRY_AUTH_TOKEN=your_sentry_auth_token_here
SENTRY_ORG=your_sentry_org_here
SENTRY_PROJECT=flagfit-pro

# =============================================================================
# COMMUNICATION SERVICES
# =============================================================================
# email-service.js checks for a transport in this order:
#   1. GMAIL_EMAIL + GMAIL_APP_PASSWORD  (Gmail SMTP)
#   2. SENDGRID_API_KEY                  (SendGrid SMTP — key used as SMTP password)
#   3. SMTP_HOST + SMTP_USER + SMTP_PASS (generic SMTP)
# Set FROM_EMAIL for the sender address; APP_URL for links in email bodies.

# Gmail SMTP
GMAIL_EMAIL=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16_character_app_password

# SendGrid SMTP (key is used as the SMTP password via smtp.sendgrid.net)
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Generic SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@domain.com
SMTP_PASS=your_email_password

# Email sender settings
FROM_EMAIL=noreply@flagfitpro.com
APP_URL=http://localhost:4000

# =============================================================================
# AI & MACHINE LEARNING SERVICES
# =============================================================================

# OpenAI (used by netlify/functions/utils/embedding-service.js and scripts/seed-knowledge-embeddings.js)
OPENAI_API_KEY=your_openai_api_key_here
