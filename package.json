ation/push-validation.test.js tests/integration/send-email-validation.test.js tests/integration/test-email-validation.test.js tests/integration/coach-activity-validation.test.js tests/integration/coach-alerts-validation.test.js tests/integration/community-validation.test.js tests/integration/decisions-validation.test.js tests/integration/exercisedb-validation.test.js tests/integration/exercises-validation.test.js tests/integration/knowledge-search-validation.test.js tests/integration/isometrics-plyometrics-validation.test.js tests/integration/response-feedback-authorization.test.js tests/integration/analytics-validation.test.js tests/integration/supplements-validation.test.js tests/integration/dashboard-validation.test.js tests/integration/coach-training-session-validation.test.js tests/integration/training-complete-validation.test.js tests/integration/trends-validation.test.js tests/integration/hydration-validation.test.js tests/integration/upload-validation.test.js tests/integration/weather-validation.test.js tests/integration/sponsor-logo-validation.test.js tests/integration/sponsors-validation.test.js tests/integration/team-templates-validation.test.js tests/integration/update-chatbot-stats-validation.test.js tests/integration/usda-sync-validation.test.js tests/integration/wellness-checkin-validation.test.js",
