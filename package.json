{
  "name": "flagfit-pro",
  "version": "1.1.0",
  "type": "module",
  "description": "FlagFit Pro - Angular 21 + PrimeNG 21 training platform with Supabase backend",
  "main": "index.js",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "start": "concurrently --kill-others-on-fail \"npm run dev:api\" \"npm run dev:angular\"",
    "dev": "concurrently --kill-others-on-fail \"npm run dev:api\" \"npm run dev:angular\"",
    "dev:api": "nodemon server.js --watch . --ext js,json --ignore node_modules/ --ignore *.backup --ignore angular/ --delay 1000ms",
    "dev:angular": "cd angular && npx ng serve --port 4200 --host 0.0.0.0 --live-reload --poll 2000",
    "dev:full": "concurrently --kill-others-on-fail \"npm run dev:api\" \"npm run dev:angular\"",
    "dev:angular-only": "cd angular && npx ng serve --port 4200 --host 0.0.0.0 --live-reload --poll 2000",
    "build": "cd angular && npm run build",
    "build:production": "cd angular && npm run build",
    "dev:netlify": "netlify dev",
    "test": "cd angular && npm run test",
    "test:unit": "cd angular && npm run test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:smoke": "cd angular && npx playwright test e2e/smoke.spec.ts",
    "test:e2e:smoke": "cd angular && npx playwright test e2e/smoke.spec.ts",
    "test:e2e:critical": "cd angular && npx playwright test e2e/critical-flow-morning-training.spec.ts",
    "test:e2e:navigation": "cd angular && npx playwright test e2e/navigation-routing.spec.ts",
    "test:e2e:navigation:watch": "cd angular && npx playwright test e2e/navigation-routing.spec.ts --headed",
    "test:watch": "cd angular && npm run test:watch",
    "test:coverage": "cd angular && npm run test:coverage",
    "test:all": "npm run test:unit && npm run test:e2e",
    "test:privacy": "npx vitest run tests/privacy-safety/",
    "test:privacy:ci": "npx vitest run tests/privacy-safety/ --reporter=verbose",
    "test:acwr": "node tests/logic/acwr-regression.test.js",
    "test:acwr:ci": "node tests/logic/acwr-regression.test.js",
    "test:ci": "cd angular && npm run test && playwright test --reporter=github",
    "verify:db": "node scripts/verify-db-objects.cjs",
    "check:consent": "node scripts/check-consent-violations.cjs",
    "check:consent:ci": "node scripts/check-consent-violations.cjs --ci --strict",
    "perf:validate": "node scripts/performance-validation.cjs",
    "perf:validate:ci": "node scripts/performance-validation.cjs --ci",
    "preflight:friday": "node scripts/preflight-friday.cjs",
    "diagnostics": "node scripts/diagnostic-system.js",
    "diagnostics:health": "node scripts/comprehensive-health-check.js",
    "diagnostics:features": "node scripts/feature-validator.js",
    "benchmark": "node scripts/performance-benchmark.js",
    "audit:security": "npm audit && node scripts/security-audit.js",
    "security:check": "npm audit --audit-level high",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "lint:css": "stylelint \"angular/src/**/*.{css,scss}\"",
    "lint:css:fix": "stylelint \"angular/src/**/*.{css,scss}\" --fix",
    "lint:css:changed": "bash scripts/lint-changed-files.sh",
    "lint:css:all": "bash scripts/lint-all-files.sh",
    "lint:all": "npm run lint && npm run lint:css && npm run lint:tokens",
    "lint:ds": "bash scripts/design-system-check.sh",
    "lint:ds:ci": "bash scripts/design-system-check.sh",
    "lint:tokens": "node scripts/lint-design-tokens.cjs",
    "lint:tokens:ci": "node scripts/lint-design-tokens.cjs --ci",
    "lint:tokens:fix": "node scripts/lint-design-tokens.cjs --fix",
    "refactor:find-dark": "node scripts/find-legacy-dark-variables.js",
    "refactor:find-dark:fix": "node scripts/find-legacy-dark-variables.js --fix",
    "refactor:component": "node scripts/systematic-refactor.js",
    "refactor:all": "node scripts/systematic-refactor.js --all",
    "quick-fixes": "node scripts/quick-fixes.js",
    "quick-fixes:apply": "node scripts/quick-fixes.js --apply",
    "storybook": "cd angular && npm run storybook",
    "storybook:build": "cd angular && npm run build-storybook",
    "storybook:test": "cd angular && npx test-storybook",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:format": "npm run lint && npm run format:check",
    "type-check": "cd angular && npm run type-check",
    "start:api": "node server.js",
    "health:check": "node scripts/comprehensive-health-check.js",
    "seed:all": "npm run seed:isometrics && npm run seed:plyometrics && npm run seed:hydration && npm run seed:supplements && npm run seed:competition && npm run seed:nutrition && npm run seed:recovery",
    "seed:isometrics": "node scripts/seedIsometricsTrainingDatabase.cjs",
    "seed:plyometrics": "node scripts/seedPlyometricsResearchDatabase.cjs",
    "seed:hydration": "node scripts/seedHydrationResearchDatabase.cjs",
    "seed:supplements": "node scripts/seedSupplementResearchDatabaseCorrected.cjs",
    "seed:competition": "node scripts/seedCompetitionProtocolsFinal.cjs",
    "seed:nutrition": "node scripts/seedNutritionSystem.cjs",
    "seed:recovery": "node scripts/seedRecoverySystem.cjs",
    "seed:wada": "node scripts/seedWADAProhibitedList.cjs",
    "seed:training": "node scripts/seedEnhancedTrainingCategories.cjs",
    "db:audit": "node scripts/database-audit.js",
    "db:tables": "node scripts/list-supabase-tables.js",
    "clean": "rm -rf dist coverage .playwright angular/dist",
    "clean:all": "rm -rf dist coverage .playwright angular/dist node_modules/.cache",
    "deploy": "./deploy-to-netlify.sh",
    "postinstall": "node scripts/fix-jws-vulnerability.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.89.0",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^7.0.12",
    "pg": "^8.16.3",
    "pg-format": "^1.0.4",
    "sql-template-strings": "^2.2.2"
  },
  "keywords": [
    "flag-football",
    "training",
    "ai-coaching",
    "olympics",
    "angular",
    "primeng",
    "supabase"
  ],
  "author": "FlagFit Pro Team",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.57.0",
    "@types/node": "^22.15.0",
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "glob": "^13.0.0",
    "globals": "^16.5.0",
    "jws": "^4.0.1",
    "madge": "^8.0.0",
    "netlify-cli": "^23.13.0",
    "nodemon": "^3.1.11",
    "playwright": "^1.57.0",
    "prettier": "^3.7.4",
    "stylelint": "^16.26.1",
    "stylelint-config-standard-scss": "^16.0.0",
    "stylelint-order": "^7.0.1",
    "stylelint-scss": "^6.14.0",
    "supabase": "^2.70.5",
    "supertest": "^7.1.4",
    "typescript": "^5.9.3",
    "ws": "^8.18.3"
  },
  "overrides": {
    "jws": "^4.0.1",
    "netlify-cli": {
      "jsonwebtoken": "^9.0.3",
      "jws": "^4.0.1"
    },
    "jsonwebtoken": {
      "jws": "^4.0.1"
    }
  }
}
