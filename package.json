{
  "name": "flagfit-pro",
  "version": "1.1.0",
  "type": "module",
  "description": "FlagFit Pro - Angular 21 training platform with Supabase backend",
  "main": "index.js",
  "engines": {
    "node": ">=22.22.3"
  },
  "scripts": {
    "start": "npm run dev",
    "dev": "netlify dev",
    "dev:api": "npm run dev",
    "dev:angular": "npm run dev:angular-only",
    "dev:full": "npm run dev",
    "dev:angular-only": "cd angular && npx ng serve --port 4200 --host 127.0.0.1 --live-reload --poll 2000",
    "build": "cd angular && npx ng build --progress=false --verbose",
    "build:production": "npm run build",
    "dev:netlify": "npm run dev",
    "test": "cd angular && npm run test",
    "test:unit": "cd angular && npm run test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:smoke": "npm run test:e2e:smoke",
    "test:e2e:smoke": "cd angular && npx playwright test e2e/smoke.spec.ts",
    "test:e2e:critical": "cd angular && npx playwright test e2e/critical-flow-morning-training.spec.ts",
    "test:e2e:navigation": "cd angular && npx playwright test e2e/navigation-routing.spec.ts",
    "test:e2e:navigation:watch": "cd angular && npx playwright test e2e/navigation-routing.spec.ts --headed",
    "test:watch": "cd angular && npm run test:watch",
    "test:coverage": "cd angular && npm run test:coverage",
    "test:all": "npm run test:unit && npm run test:e2e",
    "test:backend": "vitest run tests/integration/netlify-api.test.js",
    "test:unit:backend": "vitest run tests/unit/",
    "test:privacy": "npx vitest run tests/privacy-safety/",
    "test:privacy:ci": "npx vitest run tests/privacy-safety/ --reporter=verbose",
    "test:acwr": "node tests/logic/acwr-regression.test.js",
    "test:acwr:ci": "npm run test:acwr",
    "test:contracts": "node tests/contracts/run-contracts-test.js",
    "build:periodization-engine": "esbuild angular/src/app/core/services/periodization-engine.ts --bundle --format=esm --platform=node --banner:js=\"// GENERATED — do not edit by hand. Source of truth: angular/src/app/core/services/periodization-engine.ts. Regenerate: npm run build:periodization-engine. Parity guarded by tests/unit/periodization-port-parity.test.js.\" --outfile=netlify/functions/utils/periodization-engine.js",
    "build:periodization-input-helpers": "esbuild angular/src/app/core/services/periodization-input-helpers.ts --bundle --format=esm --platform=node --banner:js=\"// GENERATED — do not edit by hand. Source of truth: angular/src/app/core/services/periodization-input-helpers.ts. Regenerate: npm run build:periodization-input-helpers.\" --outfile=netlify/functions/utils/periodization-input-helpers.js",
    "test:ci": "cd angular && npm run test && playwright test --reporter=github",
    "preflight:deps": "node -e \"console.log('node', process.version)\" && cd angular && npm list rxjs --depth=0",
    "verify:db": "node scripts/verify-db-objects.js",
    "check:consent": "node scripts/check-consent-violations.js",
    "check:signals": "node scripts/check-signal-mutation.mjs",
    "check:consent:ci": "node scripts/check-consent-violations.js --ci --strict",
    "validate:knowledge": "node database/scripts/validate-knowledge-json.mjs",
    "scan:knowledge-secrets": "node database/scripts/scan-knowledge-secrets.mjs",
    "perf:validate": "node scripts/performance-validation.js",
    "perf:validate:ci": "node scripts/performance-validation.js --ci",
    "preflight:friday": "node scripts/preflight-friday.js",
    "diagnostics": "node scripts/diagnostic-system.js",
    "verify:supabase": "node scripts/verify-new-supabase.js",
    "update:env": "node scripts/update-env-file.js",
    "migrate:data": "node scripts/migrate-supabase-data.js",
    "migrate:quickstart": "bash scripts/migration-quickstart.sh",
    "diagnostics:health": "node scripts/comprehensive-health-check.js",
    "diagnostics:features": "node scripts/feature-validator.js",
    "audit:error-shapes": "node scripts/audit-error-shape-contracts.js",
    "audit:rls-boundaries": "node scripts/audit-rls-boundaries.js",
    "docs:regen": "node scripts/docs-regen.mjs",
    "audit:scss-duplications": "node scripts/audit-scss-duplications.js",
    "audit:scss-duplications:ci": "node scripts/audit-scss-duplications.js --ci",
    "audit:schema-drift": "node scripts/check-schema-drift.mjs",
    "benchmark": "node scripts/app-performance-check.js",
    "audit:security": "npm audit",
    "security:check": "npm audit --audit-level high",
    "lint": "cd angular && npm run lint:app",
    "lint:fix": "cd angular && npm run lint:fix",
    "lint:tooling": "eslint scripts netlify/functions --ext .js,.mjs --max-warnings=0",
    "typecheck:functions": "tsc -p netlify/functions/tsconfig.typecheck.json",
    "lint:css": "stylelint \"angular/src/**/*.{css,scss}\"",
    "lint:css:fix": "stylelint \"angular/src/**/*.{css,scss}\" --fix",
    "lint:css:changed": "bash scripts/lint-changed-files.sh",
    "lint:css:all": "bash scripts/lint-all-files.sh",
    "lint:design-system": "bash scripts/design-system-check.sh",
    "lint:all": "npm run lint && npm run lint:tooling && npm run lint:design-system && npm run lint:css && npm run lint:tokens && npm run check:signals",
    "lint:ds": "npm run lint:design-system",
    "lint:ds:ci": "npm run lint:design-system",
    "lint:tokens": "node scripts/lint-design-tokens.js",
    "lint:tokens:ci": "node scripts/lint-design-tokens.js --ci",
    "lint:tokens:fix": "node scripts/lint-design-tokens.js --fix",
    "refactor:find-dark": "node scripts/find-legacy-dark-variables.js",
    "refactor:find-dark:fix": "node scripts/find-legacy-dark-variables.js --fix",
    "refactor:component": "node scripts/systematic-refactor.js",
    "refactor:all": "node scripts/systematic-refactor.js --all",
    "quick-fixes": "node scripts/quick-fixes.js",
    "quick-fixes:apply": "node scripts/quick-fixes.js --apply",
    "storybook": "cd angular && npm run storybook",
    "storybook:build": "cd angular && npm run build-storybook",
    "storybook:test": "cd angular && npx test-storybook",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:format": "npm run lint && npm run format:check",
    "type-check": "cd angular && npm run type-check",
    "start:api": "npm run dev",
    "smoke:check": "bash scripts/smoke-check.sh",
    "health:check": "npm run diagnostics:health",
    "db:audit": "node scripts/database-audit.js",
    "db:tables": "node scripts/list-supabase-tables.js",
    "clean": "rm -rf dist coverage .playwright angular/dist",
    "clean:all": "rm -rf dist coverage .playwright angular/dist node_modules/.cache",
    "deploy": "./deploy-to-netlify.sh",
    "postinstall": "node scripts/fix-jws-vulnerability.js",
    "css:coverage": "node scripts/css-coverage.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.7",
    "ajv": "^8.17.1",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "date-fns": "^4.4.0",
    "dotenv": "^17.2.4",
    "isomorphic-dompurify": "^3.18.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^9.0.3",
    "papaparse": "^5.5.4",
    "pg": "^8.22.0",
    "pg-format": "^1.0.4",
    "sql-template-strings": "^2.2.2",
    "stripe": "^22.3.2",
    "web-push": "^3.6.7"
  },
  "keywords": [
    "flag-football",
    "training",
    "ai-coaching",
    "olympics",
    "angular",
    "supabase"
  ],
  "author": "FlagFit Pro Team",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.15.0",
    "concurrently": "^10.0.3",
    "eslint": "^10.7.0",
    "express": "^5.2.1",
    "glob": "^13.0.6",
    "globals": "^17.3.0",
    "jws": "^4.0.1",
    "netlify-cli": "^26.2.0",
    "playwright": "^1.61.1",
    "prettier": "^3.8.4",
    "sass": "^1.101.0",
    "stylelint": "^16.26.1",
    "stylelint-config-standard-scss": "^16.0.0",
    "stylelint-order": "^7.0.1",
    "stylelint-scss": "^7.0.0",
    "supabase": "^2.109.1",
    "supertest": "^7.1.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "jws": "^4.0.1",
    "netlify-cli": {
      "jsonwebtoken": "^9.0.3",
      "jws": "^4.0.1"
    },
    "jsonwebtoken": {
      "jws": "^4.0.1"
    }
  }
}
