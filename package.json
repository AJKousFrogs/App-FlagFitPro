  "scripts": {
    "dev": "node scripts/dev-with-port-management.js",
    "dev:unsafe": "vite",
    "dev:polling": "VITE_USE_POLLING=true npm run dev",
    "dev:fresh": "npm run clean && npm run dev",
    "dev:clean": "./dev-clean.sh",
    "dev:clean-fresh": "./dev-clean.sh --fresh",
    "port:info": "node scripts/port-manager.js info",
    "port:cleanup": "node scripts/port-manager.js cleanup",
    "port:release-all": "node scripts/port-manager.js release-all",
    "health:check": "node scripts/health-check-enhanced.js check",
    "health:monitor": "node scripts/health-check-enhanced.js monitor",
    "server": "node server.js",
    "dev:full": "concurrently \"npm run server\" \"npm run dev\"",
    "mcp:start": "node scripts/mcp-server-manager.js start",
    "mcp:stop": "node scripts/mcp-server-manager.js stop",
    "mcp:restart": "node scripts/mcp-server-manager.js restart",
    "mcp:status": "node scripts/mcp-server-manager.js status",
    "mcp:health": "node scripts/mcp-server-manager.js health",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "db:setup": "node scripts/setupDatabase.js",
    "db:migrate": "node scripts/runMigrations.js",
    "db:seed:nutrition": "node scripts/seedComprehensiveNutritionDatabase.js",
    "db:seed:recovery": "node scripts/seedRecoveryScienceDatabase.js",
    "db:seed:coaches": "node scripts/seedAICoachesDatabase.js",
    "db:seed:research": "node scripts/seedSportsScienceResearch.js",
    "db:seed:psychology": "node scripts/seedEnhancedSportPsychologyDatabase.js",
    "db:seed:nutrition-enhanced": "node scripts/seedEnhancedSportsNutritionDatabase.js",
    "db:integrate:apis": "node scripts/integrateSportsMedicineAPIs.js",
    "db:seed:flagfootball": "node scripts/seedFlagFootballTrainingDatabase.js",
    "build": "vite build",
    "build:clean": "npm run clean && npm run build",
    "clean": "rimraf dist node_modules/.vite",
    "clean:cache": "rimraf node_modules/.vite",
    "clean:full": "rimraf dist node_modules/.vite node_modules package-lock.json && npm install",
    "clean:node": "rimraf node_modules package-lock.json && npm install",
    "cache:clear": "echo '\n🧹 Service Worker Cache Cleaner\n================================\n\n✅ Service Worker disabled in development\n💡 Visit http://localhost:4000/cleanup.html for automated cleanup\n📝 Manual steps: Open DevTools → Application → Clear site data\n🔄 Hard refresh: Ctrl+Shift+R (Cmd+Shift+R on Mac)\n'",
    "troubleshoot": "npm run clean:cache && npm run check:full && npm run dev",
    "debug": "npm run clean:node && npm run check:full",
    "check:location": "node -e \"console.log('Project location:', process.cwd()); const path = process.cwd(); if(path.includes('OneDrive') || path.includes('Dropbox') || path.includes('Google Drive') || path.includes('iCloud')) console.warn('⚠️ WARNING: Project is in cloud-synced folder!'); else console.log('✅ Project location is good');\"",
    "check:permissions": "node -e \"const fs = require('fs'); try { fs.accessSync('.', fs.constants.R_OK | fs.constants.W_OK); console.log('✅ File permissions OK'); } catch (err) { console.error('❌ File permission error:', err.message); }\"",
    "check:env": "npm run check:location && npm run check:permissions && node --version && npm --version",
    "check:full": "node scripts/dev-environment-check.cjs",
    "doctor": "npm run check:full",
    "env:setup": "cp .env.example .env && echo '✅ .env file created from template. Please edit with your actual values.'",
    "env:validate": "node -e \"const fs=require('fs'); const env=fs.readFileSync('.env','utf8'); if(env.includes('your_')||env.includes('_here')) console.log('⚠️ .env contains placeholder values - update with real values'); else console.log('✅ .env appears to have real values');\"",
    "env:security": "git check-ignore .env && echo '✅ .env properly ignored by git' || echo '❌ .env NOT ignored - check .gitignore'",
    "preview": "vite preview",
    "db:generate": "drizzle-kit generate",
    "db:migrate-drizzle": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:reset": "drizzle-kit drop && drizzle-kit push",
    "db:seed": "node scripts/seed-database.js",
    "db:setup-full": "npm run db:generate && npm run db:migrate-drizzle && npm run db:seed",
    "seed:food": "node scripts/seedFoodDatabase.js",
    "seed:food:force": "node scripts/seedFoodDatabase.js --force",
    "seed:food:dry-run": "node scripts/seedFoodDatabase.js --dry-run",
    "seed:food:category": "node scripts/seedFoodDatabase.js --category=",
    "backend:migrate": "node database/migrate.js",
    "backend:seed": "node scripts/seedFoodDatabase.js",
    "generate-icons": "open public/icons/generate-missing-icons.html",
    "generate-svg-icons": "node scripts/generate-missing-icons.js"
  }
