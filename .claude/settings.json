{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@context7/mcp-server@latest"
      ],
      "env": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}",
        "CONTEXT7_PORT": "3000",
        "CONTEXT7_DOMAIN": "sports-science",
        "CONTEXT7_CATEGORIES": "nutrition,training,recovery,psychology,biomechanics"
      },
      "allowedTools": [
        "resolve-library-id",
        "get-library-docs"
      ],
      "description": "Context7 - Software documentation finder for sports science and development libraries",
      "alwaysAllow": []
    },
    "sequential-thought": {
      "command": "npx",
      "args": [
        "-y",
        "@sequential-thought/mcp-server@latest"
      ],
      "env": {
        "SEQUENTIAL_THOUGHT_PORT": "3001",
        "ST_REASONING_DEPTH": "3",
        "ST_DOMAIN": "sports-coaching"
      },
      "allowedTools": [
        "sequentialthinking"
      ],
      "description": "Sequential Thought - Chain-of-thought reasoning framework for complex decision making",
      "alwaysAllow": []
    }
  },
  "allowedTools": [
    "resolve-library-id",
    "get-library-docs",
    "sequentialthinking",
    "Bash",
    "Read",
    "Write",
    "Edit",
    "MultiEdit",
    "Glob",
    "Grep",
    "LS",
    "WebFetch",
    "WebSearch",
    "TodoWrite",
    "Task"
  ],
  "maxTokens": 100000,
  "temperature": 0.7,
  "enableDevtools": true,
  "autoSave": true,
  "workspaceSettings": {
    "projectName": "FlagFit Pro",
    "projectType": "angular-supabase-sports-app",
    "framework": "Angular 21 + PrimeNG 21 + TypeScript",
    "database": "Supabase (PostgreSQL)",
    "ui": "PrimeNG 21 + SCSS + Design Tokens",
    "features": [
      "AI Coaching System",
      "Nutrition Tracking",
      "Recovery Monitoring",
      "Performance Analytics",
      "Training Schedules",
      "Player Leaderboards",
      "Community Features"
    ],
    "localDevelopment": {
      "startCommand": "npm run dev",
      "netlifyDev": "localhost:8888",
      "envFile": ".env (must have valid Supabase keys)"
    }
  },
  "contextFiles": [
    "package.json",
    "angular/angular.json",
    "angular/src/main.ts",
    "docs/ARCHITECTURE.md",
    "docs/FEATURE_DOCUMENTATION.md",
    "docs/DOCS_INDEX.md"
  ],
  "ignorePatterns": [
    "node_modules/**",
    "dist/**",
    "build/**",
    ".git/**",
    "*.log",
    ".env.local",
    ".env.production"
  ],
  "shortcuts": {
    "dev": "npm run dev",
    "build": "npm run build",
    "test": "npm run test",
    "lint": "npm run lint",
    "health": "npm run health:check",
    "ports": "npm run port:info"
  }
}