{
  "name": "flagfit-pro-fresh-start",
  "version": "1.0.8",
  "type": "module",
  "description": "FlagFit Pro - Complete flag football training and analytics platform",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js --watch . --ext js,json,html,css --ignore node_modules/ --ignore *.backup",
    "build": "npm install && echo 'Static site build completed'",
    "postbuild": "echo 'Post-build tasks completed'",
    "seed": "node scripts/seedDashboardData.js",
    "setup": "npm install && npm run seed",
    "test": "node scripts/test-dashboard.js",
    "clean": "rm -rf node_modules package-lock.json && npm install",
    "security-audit": "npm audit --audit-level moderate",
    "deployment-check": "node scripts/deployment-check.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "chart.js": "^4.4.6",
    "cors": "^2.8.5", 
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "jsonwebtoken": "^9.0.2",
    "node-fetch": "^3.3.2",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "nodemon": "^3.1.7",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.15"
  },
  "keywords": [
    "flag-football",
    "sports-analytics", 
    "dashboard",
    "athletics",
    "performance-tracking",
    "tournament-management",
    "netlify",
    "nodejs",
    "express"
  ],
  "author": "FlagFit Pro Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AJKous31/app-new-flag.git"
  },
  "bugs": {
    "url": "https://github.com/AJKous31/app-new-flag/issues"
  },
  "homepage": "https://github.com/AJKous31/app-new-flag#readme"
}