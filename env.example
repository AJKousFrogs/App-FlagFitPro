# Database Configuration  
VITE_NEON_DATABASE_URL=postgresql://your_user:your_pass@your_host/your_db
DATABASE_URL=postgresql://your_user:your_pass@your_host/your_db

# API Configuration
VITE_API_TIMEOUT=30000
VITE_CACHE_TTL=300000

# Development Configuration
VITE_DEV_MODE=true
VITE_DEBUG_LOGGING=false

# Neon Database Configuration
VITE_NEON_DATABASE_URL=postgresql://your_neon_user:your_neon_password@your_neon_host/your_neon_db
NETLIFY_DATABASE_URL=postgresql://your_neon_user:your_neon_password@your_neon_host/your_neon_db
NETLIFY_DATABASE_URL_UNPOOLED=postgresql://your_neon_user:your_neon_password@your_neon_host/your_neon_db

# External API Keys
VITE_OPENAI_API_KEY=your_openai_api_key_here
VITE_USDA_API_KEY=your_usda_api_key_here
VITE_WEATHER_API_KEY=your_weather_api_key_here

# Feature Flags
VITE_ENABLE_AI_COACH=true
VITE_ENABLE_HYDRATION_SYSTEM=true
VITE_ENABLE_RECOVERY_SYSTEM=true
VITE_ENABLE_OLYMPIC_TRACKING=true
VITE_ENABLE_SPONSOR_SYSTEM=true

# Analytics and Monitoring
VITE_SENTRY_DSN=your_sentry_dsn_here
VITE_GOOGLE_ANALYTICS_ID=your_ga_id_here 